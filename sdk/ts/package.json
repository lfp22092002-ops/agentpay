{
  "name": "agentpay",
  "version": "0.1.1",
  "description": "TypeScript SDK for AgentPay — payment infrastructure for AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "ai",
    "agents",
    "payments",
    "crypto",
    "usdc",
    "x402",
    "telegram"
  ],
  "author": "AgentPay <hello@leofundmybot.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lfp22092002-ops/agentpay"
  },
  "homepage": "https://leofundmybot.dev",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  }
}
